---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchWeeklyEvents, fetchSiteSettings } from '../lib/sanity.js';
import { stegaClean } from '@sanity/client/stega';

// ── Fallback data (used when Sanity is not yet connected) ──────────────────────
const fallbackEvents = [
  {
    day: 'Monday',
    eventName: 'Karaoke Night',
    deals: ['$8 Bottles of Wine', '$4 Spartan Light Pitchers', "$4 Cat’s PJs · Green Tea Shots", 'Half-Off Apps'],
    stampLines: ['Grab', 'The', 'Mic'],
    order: 1,
  },
  {
    day: 'Tuesday',
    eventName: 'Honky Tonk',
    deals: ['$4 Spartan Light Pitchers', '$4 Apple Pie Seltzers', '$4 Jack Daniels', '$8 Personal Pizza'],
    stampLines: ['Country', 'All', 'Night'],
    order: 2,
  },
  {
    day: 'Wednesday',
    eventName: 'Half Off Night',
    deals: ['$2.75 Harper’s Vodka', '$3 Wings', '$5 Chicken Dillas · Burgers', '$8 Large Pizza'],
    stampLines: ['Best', 'Deal of', 'the Week'],
    order: 3,
  },
  {
    day: 'Thursday',
    eventName: 'Patio DJ Night',
    deals: ['Open-Air Sets', 'String Lights & Fire Pits', 'Heaters Cranked', 'Dinner Crowd Welcome'],
    stampLines: ['On the', 'Patio'],
    order: 4,
  },
  {
    day: 'Friday',
    eventName: 'Friday Night',
    deals: ['$4 Long Islands', '$4 Spartan Light Pitchers', '$6 Wings'],
    stampLines: ['Weekend', 'Mode'],
    order: 5,
  },
  {
    day: 'Saturday',
    eventName: 'Game Day → After Dark',
    deals: ['Every Screen On at Noon', 'Club Rush Opens at Nine', 'One Building, All Day'],
    stampLines: ['Game', 'Day HQ'],
    order: 6,
  },
];

const fallbackSettings = {
  phone: '517-333-4040',
  email: 'Harpersbrewpub@aol.com',
  hoursDisplay: '12:00pm – 2:00am',
  shellyPhone: '517-333-4040',
  shellyAvailability: 'Mon–Fri, 9am–5pm',
};

// ── Fetch from Sanity (silently falls back if not connected) ───────────────────
const sanityEvents   = await fetchWeeklyEvents();
const sanitySettings = await fetchSiteSettings();

const events   = (sanityEvents  && sanityEvents.length)  ? sanityEvents   : fallbackEvents;
const settings = sanitySettings || fallbackSettings;

// Helper: reveal-delay class cycles every 3 cards
const revealClass = (i: number) => ['reveal', 'reveal reveal-delay-1', 'reveal reveal-delay-2'][i % 3];
---

<BaseLayout>

  <!-- ═══════════════════════════════════════════════════ NAV -->
  <nav class="site-nav" id="site-nav">
    <div class="nav-inner">
      <a href="#" class="nav-logo" aria-label="Harper's  Home">
        <img src="/Photos/harpers-logo.png" alt="Harper's Restaurant &amp; Brewpub  East Lansing, MI" class="logo-img"
          onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
        <span class="logo-text-fallback">HARPER'S</span>
      </a>
      <button class="nav-hamburger" id="nav-hamburger" aria-label="Open navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links" id="nav-links" role="list">
        <li><a href="#this-week">What's On</a></li>
        <li><a href="#patio">The Patio</a></li>
        <li><a href="#food">Food &amp; Beer</a></li>
        <li><a href="#nightlife">Club Rush</a></li>
        <li><a href="#gameday">Game Day</a></li>
        <li><a href="#events">Private Events</a></li>
        <li><a href="#find-us">Visit</a></li>
        <li><a href="https://harpers-east-lansing.myshopify.com/" target="_blank" rel="noopener" class="nav-cta">Shop Merch</a></li>
      </ul>
    </div>
  </nav>

  <div class="nav-overlay" id="nav-overlay" aria-hidden="true"></div>

  <!-- ═══════════════════════════════════════════════════ HERO -->
  <section class="hero" id="hero" aria-label="Harper's  East Lansing's Favorite Bar Since 1997">
    <div class="hero-bg">
      <video class="hero-img hero-video" autoplay muted loop playsinline preload="metadata" poster="/Photos/Harps_Feb11-28_no-logo_16x9.webp" aria-hidden="true">
        <source src="/Videos/BANNER.mp4#t=0.001" type="video/mp4" media="(min-width: 901px)">
        <source src="/Videos/harpers-hero-pour-16x9.mp4#t=0.001" type="video/mp4" media="(min-width: 901px)">
      </video>
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-content">
      <div class="hero-logo logo-animate">
        <img src="/Photos/harpers-logo.png" alt="Harper's Restaurant &amp; Brewpub  East Lansing's bar since 1997"
          fetchpriority="high" decoding="async"
          onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
        <span class="hero-logo-text">HARPER'S</span>
      </div>
      <p class="hero-award hero-reveal" style="--delay:0.9s">
        Voted Best in East Lansing &nbsp;&middot;&nbsp; 3 Years Running &nbsp;&middot;&nbsp; State News Best Of
      </p>
      <h1 class="hero-tagline hero-reveal" style="--delay:1.4s">
        Drinks Upstairs.<br>DJs Downstairs.<br><em>Patio Out Back.</em>
      </h1>
      <div class="hero-ctas hero-reveal" style="--delay:2.0s">
        <a href="#this-week" class="btn btn-amber">What's On This Week</a>
        <a href="https://www.harpersbrewpub.com/menu" target="_blank" rel="noopener" class="btn btn-ghost">See the Menu</a>
      </div>
    </div>
    <div class="hero-scroll-cue" aria-hidden="true">
      <span class="scroll-label">Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ THIS WEEK (DYNAMIC) -->
  <section class="thisweek" id="this-week">
    <div class="thisweek-inner">
      <div class="thisweek-header reveal">
        <span class="section-label">This Week at Harper's</span>
        <h2 class="section-heading">What's<br><em>On.</em></h2>
        <p class="thisweek-sub">Doors at noon, kitchen 'til midnight, last call at two. Updated every Monday.</p>
      </div>
      <div class="event-cards-grid">
        {events.map((event: any, i: number) => (
          <article class={`event-card card-${stegaClean(event.day).toLowerCase()} ${revealClass(i)}`}>
            <div class="ecard-bg"></div>
            <div class="ecard-overlay"></div>
            <div class="ecard-inner">
              <span class="ecard-day">{event.day}</span>
              <h3 class="ecard-name">{event.eventName}</h3>
              <div class="ecard-divider"></div>
              <ul class="ecard-deals">
                {event.deals.map((deal: string) => <li>{deal}</li>)}
              </ul>
              <div class="ecard-stamp" set:html={(event.stampLines || []).join('<br>')}></div>
            </div>
          </article>
        ))}
      </div>
      <div class="ll-cta-wrap ll-cta-events reveal">
        <span class="ll-label">Already on LineLeap? Skip the wait.</span>
        <a href="https://tickets.lineleap.com/venues/bdA93uf8y8KKU2eoZvLv" target="_blank" rel="noopener" class="ll-btn">Skip the Line Any Night &rarr;</a>
      </div>
    </div>
    <div class="drink-arm-wrap" aria-hidden="true">
      <img src="/Photos/Adobe Express - file (1).png" class="drink-arm" alt="">
    </div>
    <div class="about-jit-wrap" aria-hidden="true">
      <img src="/Photos/JIT.png" class="about-jit" alt="">
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ ABOUT -->
  <section class="about" id="about">
    <div class="about-inner">
      <div class="about-text reveal">
        <span class="section-label">Since 1997 &nbsp;&middot;&nbsp; East Lansing, MI</span>
        <h2 class="section-heading">Built for Every<br><em>Kind of Night.</em></h2>
        <p class="about-body">Harper's has been East Lansing's gathering spot for twenty-eight years. Upstairs is the bar, the kitchen, the screens, and the patio. Downstairs is Club Rush  fog cannons, concert lighting, and the loudest weekend on Albert Ave. Same family running the place since day one. Different scene every night of the week.</p>
        <p class="about-tagline">Family Owned &nbsp;&middot;&nbsp; Kitchen Open Late &nbsp;&middot;&nbsp; Beer Brewed Downstairs</p>
      </div>
      <div class="about-photos reveal reveal-delay-1">
        <div class="about-photo about-photo-top">
          <picture>
            <source srcset="/Photos/Patio-52.webp" type="image/webp">
            <img src="/Photos/Patio-52.jpg" alt="Friends dining on the Harper's patio in East Lansing, MI  string lights and pergola overhead" loading="lazy" decoding="async" width="400" height="600">
          </picture>
        </div>
        <div class="about-photo about-photo-bottom">
          <picture>
            <source srcset="/Photos/DOD_ClubRush-03.webp" type="image/webp">
            <img src="/Photos/DOD_ClubRush-03.jpg" alt="Club Rush nightclub at Harper's East Lansing  packed dance floor, fog cannons, concert lighting" loading="lazy" decoding="async" width="400" height="600">
          </picture>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider: cream → teal -->
  <div class="divider-rough db-teal" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,62 C360,84 480,26 720,50 C960,74 1200,22 1440,36 L1440,0 L0,0 Z" fill="#FFFBF4"/>
    </svg>
  </div>

  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      <span>DOORS AT NOON &nbsp;&middot;&nbsp; LAST CALL AT 2AM &nbsp;&middot;&nbsp; PATIO OPEN &nbsp;&middot;&nbsp; KITCHEN ON &nbsp;&middot;&nbsp; BEER FLOWING &nbsp;&middot;&nbsp; CLUB RUSH DOWNSTAIRS &nbsp;&middot;&nbsp; GAME DAY HQ &nbsp;&middot;&nbsp; HALF-OFF WEDNESDAYS &nbsp;&middot;&nbsp; SEVEN DAYS A WEEK &nbsp;&middot;&nbsp; 131 ALBERT AVE &nbsp;&middot;&nbsp; EAST LANSING&rsquo;S BAR SINCE 1997 &nbsp;&middot;&nbsp; &nbsp;</span>
      <span>DOORS AT NOON &nbsp;&middot;&nbsp; LAST CALL AT 2AM &nbsp;&middot;&nbsp; PATIO OPEN &nbsp;&middot;&nbsp; KITCHEN ON &nbsp;&middot;&nbsp; BEER FLOWING &nbsp;&middot;&nbsp; CLUB RUSH DOWNSTAIRS &nbsp;&middot;&nbsp; GAME DAY HQ &nbsp;&middot;&nbsp; HALF-OFF WEDNESDAYS &nbsp;&middot;&nbsp; SEVEN DAYS A WEEK &nbsp;&middot;&nbsp; 131 ALBERT AVE &nbsp;&middot;&nbsp; EAST LANSING&rsquo;S BAR SINCE 1997 &nbsp;&middot;&nbsp; &nbsp;</span>
      <span>DOORS AT NOON &nbsp;&middot;&nbsp; LAST CALL AT 2AM &nbsp;&middot;&nbsp; PATIO OPEN &nbsp;&middot;&nbsp; KITCHEN ON &nbsp;&middot;&nbsp; BEER FLOWING &nbsp;&middot;&nbsp; CLUB RUSH DOWNSTAIRS &nbsp;&middot;&nbsp; GAME DAY HQ &nbsp;&middot;&nbsp; HALF-OFF WEDNESDAYS &nbsp;&middot;&nbsp; SEVEN DAYS A WEEK &nbsp;&middot;&nbsp; 131 ALBERT AVE &nbsp;&middot;&nbsp; EAST LANSING&rsquo;S BAR SINCE 1997 &nbsp;&middot;&nbsp; &nbsp;</span>
      <span>DOORS AT NOON &nbsp;&middot;&nbsp; LAST CALL AT 2AM &nbsp;&middot;&nbsp; PATIO OPEN &nbsp;&middot;&nbsp; KITCHEN ON &nbsp;&middot;&nbsp; BEER FLOWING &nbsp;&middot;&nbsp; CLUB RUSH DOWNSTAIRS &nbsp;&middot;&nbsp; GAME DAY HQ &nbsp;&middot;&nbsp; HALF-OFF WEDNESDAYS &nbsp;&middot;&nbsp; SEVEN DAYS A WEEK &nbsp;&middot;&nbsp; 131 ALBERT AVE &nbsp;&middot;&nbsp; EAST LANSING&rsquo;S BAR SINCE 1997 &nbsp;&middot;&nbsp; &nbsp;</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════ PATIO -->
  <section class="patio" id="patio">
    <div class="patio-header reveal">
      <span class="section-label light">The Patio</span>
      <h2 class="section-heading light">Meet Me<br><em>on the Patio.</em></h2>
    </div>
    <div class="patio-photos">
      <div class="patio-photo reveal">
        <picture>
          <source srcset="/Photos/Patio-07.webp" type="image/webp">
          <img src="/Photos/Patio-07.jpg" alt="Harper's outdoor patio in East Lansing  string lights, fire pits, and the patio DJ booth" loading="lazy" decoding="async" width="600" height="900">
        </picture>
        <div class="patio-photo-caption">String lights, fire pits, and the best patio DJ in East Lansing.</div>
      </div>
      <div class="patio-photo reveal reveal-delay-1">
        <picture>
          <source srcset="/Photos/Patio-52.webp" type="image/webp">
          <img src="/Photos/Patio-52.jpg" alt="MSU students on the Harper's East Lansing patio at night  vine-draped pergola and string lights" loading="lazy" decoding="async" width="600" height="900">
        </picture>
        <div class="patio-photo-caption">Dinner crowd by seven. Loudest patio in town by eleven.</div>
      </div>
    </div>
    <div class="patio-copy reveal">
      <p>The patio is the heart of Harper's  open-air seating, heaters when it's cold, and a DJ booth that turns the courtyard into the loudest open-air bar in East Lansing. Come for dinner under the string lights. Stay through last call. Either way, you'll see everyone you know.</p>
    </div>
  </section>

  <!-- Divider: teal → cream -->
  <div class="divider-rough db-cream" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,55 C200,75 400,25 640,48 C880,71 1120,20 1440,38 L1440,0 L0,0 Z" fill="#00B5BF"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════════════ FOOD & DRINKS -->
  <section class="food" id="food">
    <div class="food-header">
      <div class="food-header-text reveal">
        <span class="section-label">Kitchen &amp; Bar</span>
        <h2 class="section-heading">Not Just a Bar That<br><em>Serves Food.</em></h2>
      </div>
      <div class="food-badges reveal reveal-delay-1">
        <span class="badge">Stone-Fired Pizza</span>
        <span class="badge">Hand-Pressed Burgers</span>
        <span class="badge">Brewed On Site</span>
      </div>
    </div>
    <div class="food-grid">
      <div class="food-item food-hero reveal">
        <picture>
          <source srcset="/Photos/Harps_Feb11-12.webp" type="image/webp">
          <img src="/Photos/Harps_Feb11-12.jpg" alt="Spinach pesto stone-fired pizza at Harper's Restaurant &amp; Brewpub in East Lansing  house-made pesto, goat and feta cheese" loading="lazy" decoding="async" width="600" height="900">
        </picture>
        <div class="food-label">
          <span class="food-tag">Most Ordered</span>
          <strong class="food-name">Spinach Pesto Pizza</strong>
          <p>Fresh spinach, house-made pesto, goat and feta, roasted onions, pine nuts. Stone oven. Twelve minutes.</p>
          <a href="https://www.harpersbrewpub.com/menu" target="_blank" rel="noopener" class="food-link">See Full Menu &rarr;</a>
        </div>
      </div>
      <div class="food-item reveal reveal-delay-1">
        <picture>
          <source srcset="/Photos/Harps_Feb11-17.webp" type="image/webp">
          <img src="/Photos/Harps_Feb11-17.jpg" alt="Stone-fired pepperoni pizza from Harper's scratch kitchen in East Lansing" loading="lazy" decoding="async" width="400" height="600">
        </picture>
      </div>
      <div class="food-item reveal reveal-delay-2">
        <picture>
          <source srcset="/Photos/Harps_Feb11-16.webp" type="image/webp">
          <img src="/Photos/Harps_Feb11-16.jpg" alt="Two stone-fired pizzas at Harper's East Lansing  pepperoni and spinach pesto sharing the table" loading="lazy" decoding="async" width="400" height="600">
        </picture>
      </div>
      <div class="food-item food-wide reveal reveal-delay-1">
        <picture>
          <source srcset="/Photos/Harps_Feb11-60.webp" type="image/webp">
          <img src="/Photos/Harps_Feb11-60.jpg" alt="Late-night app spread at Harper's East Lansing  fries, mozzarella sticks, and signature drinks" loading="lazy" decoding="async" width="400" height="600">
        </picture>
        <div class="food-label food-label-overlay">
          <strong class="food-name">Fries, Apps, Late Nights.</strong>
        </div>
      </div>
    </div>
    <div class="food-drinks-strip">
      <div class="food-item reveal">
        <img src="/Photos/Harps_Feb11-28.jpg" alt="Bartender at Harper's East Lansing pouring a signature drink  Cat's Pajamas and Gypsy Vodka on the menu" loading="lazy" decoding="async" width="400" height="600">
        <div class="food-label food-label-overlay">
          <strong class="food-name">Cat's Pajamas. Gypsy Vodkas. The Pours You Came For.</strong>
        </div>
      </div>
      <div class="food-item reveal reveal-delay-1">
        <picture>
          <source srcset="/Photos/Harps_Feb11-25.webp" type="image/webp">
          <img src="/Photos/Harps_Feb11-25.jpg" alt="MSU students cheersing drinks at Harper's bar in East Lansing" loading="lazy" decoding="async" width="400" height="600">
        </picture>
      </div>
    </div>
    <div class="food-ctas reveal">
      <a href="https://www.harpersbrewpub.com/menu" target="_blank" rel="noopener" class="btn btn-primary">Food Menu</a>
      <a href="https://www.harpersbrewpub.com/beer" target="_blank" rel="noopener" class="btn btn-outline">Beer Menu</a>
    </div>
  </section>

  <!-- Divider: cream → dark -->
  <div class="divider-rough db-navy" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,75 C400,88 900,10 1440,28 L1440,0 L0,0 Z" fill="#FFFBF4"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════════════ GAME DAY -->
  <section class="gameday" id="gameday">
    <div class="gameday-bg" aria-hidden="true">
      <picture>
        <source srcset="/Photos/Patio-77.webp" type="image/webp">
        <img src="/Photos/Patio-77.jpg" alt="" class="gameday-img" loading="lazy" decoding="async" width="1200" height="1800">
      </picture>
      <div class="gameday-overlay"></div>
    </div>
    <div class="gameday-content">
      <span class="section-label light reveal">Game Day</span>
      <h2 class="gameday-heading" id="gameday-heading" aria-label="The Loudest Saturday in East Lansing">
        <span class="wd">The</span>&nbsp;<span class="wd">Loudest</span>&nbsp;<span class="wd">Saturday</span><br>
        <span class="wd">in</span>&nbsp;<span class="wd">East</span>&nbsp;<span class="wd">Lansing.</span>
      </h2>
      <p class="gameday-sub reveal reveal-delay-2">Every screen on the game. Doors at noon for tailgating, kitchen open through the fourth quarter, and the patio packed by sundown. Whether you're here for MSU football or watching the away game with 499 of your closest fans  Saturday starts at Harper's.</p>
      <div class="gameday-stats">
        <div class="gameday-stat reveal reveal-delay-3">
          <span class="stat-big counter" data-target="500">500</span>
          <span class="stat-label">fans, one room</span>
        </div>
        <div class="gameday-stat reveal reveal-delay-3" style="--extra-delay:0.1s">
          <span class="stat-big counter" data-target="28">28</span>
          <span class="stat-label">seasons strong</span>
        </div>
        <div class="gameday-stat reveal reveal-delay-3" style="--extra-delay:0.2s">
          <span class="stat-big">12pm</span>
          <span class="stat-label">doors every game day</span>
        </div>
      </div>
      <div class="ll-cta-wrap ll-cta-gameday reveal reveal-delay-3">
        <a href="https://tickets.lineleap.com/venues/bdA93uf8y8KKU2eoZvLv" target="_blank" rel="noopener" class="ll-btn ll-btn-amber ll-btn-glow-amber">Game Day Pass &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ NIGHTLIFE / CLUB RUSH -->
  <section class="nightlife" id="nightlife">
    <div class="nightlife-slides" id="nightlife-slides" aria-hidden="true">
      <div class="slide active" style="background-image:url('/Photos/DOD_ClubRush-03.webp')"></div>
      <div class="slide" data-bg="/Photos/Deerock @ Harper's.jpg"></div>
      <div class="slide" data-bg="/Photos/Patio-74.webp"></div>
      <div class="slide" data-bg="/Photos/Patio-87.webp"></div>
    </div>
    <div class="nightlife-overlay" aria-hidden="true"></div>
    <div class="nightlife-glow" id="nightlife-glow" aria-hidden="true"></div>
    <div class="nightlife-content">
      <span class="section-label nightlife-label reveal">Club Rush &nbsp;&middot;&nbsp; Downstairs at Harper's</span>
      <h2 class="nightlife-heading reveal reveal-delay-1">
        Friday.<br>Saturday.<br><em>Every Night.</em>
      </h2>
      <p class="nightlife-sub reveal reveal-delay-2">Downstairs is Club Rush  East Lansing's nightclub. Touring DJ talent, fog cannons, concert-grade lighting, and a floor that doesn't quit until last call. Names like Ian Asher, D.O.D., and Sidequest on the main stage. The nights between, we throw ourselves.</p>
      <div class="nightlife-ctas reveal reveal-delay-3">
        <a href="https://www.harpersbrewpub.com/events" target="_blank" rel="noopener" class="btn btn-light">See What's Booked</a>
        <a href="https://tickets.lineleap.com/venues/bdA93uf8y8KKU2eoZvLv" target="_blank" rel="noopener" class="btn btn-ghost-light">Skip the Line</a>
      </div>
      <div class="ll-cta-wrap ll-cta-clubrush reveal reveal-delay-3">
        <a href="https://tickets.lineleap.com/venues/bdA93uf8y8KKU2eoZvLv" target="_blank" rel="noopener" class="ll-btn ll-btn-large ll-btn-amber ll-btn-glow-amber">Buy Tickets &amp; Skip the Line &rarr;</a>
        <p class="ll-powered">Powered by LineLeap &nbsp;&middot;&nbsp; Opens in app</p>
      </div>
    </div>
    <div class="nightlife-dots" id="nightlife-dots" aria-label="Slideshow controls">
      <button class="dot active" data-slide="0" aria-label="Photo 1"></button>
      <button class="dot" data-slide="1" aria-label="Photo 2"></button>
      <button class="dot" data-slide="2" aria-label="Photo 3"></button>
      <button class="dot" data-slide="3" aria-label="Photo 4"></button>
    </div>
  </section>

  <!-- Divider: dark → cream -->
  <div class="divider-rough db-cream" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,68 C600,92 960,15 1440,32 L1440,0 L0,0 Z" fill="#09081C"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════════════ EVENTS -->
  <section class="events" id="events">
    <div class="events-inner">
      <div class="events-text reveal">
        <span class="section-label">Private Events</span>
        <h2 class="section-heading">The Whole Building<br><em>Is Yours.</em></h2>
        <p>Greek life formals. Fraternity rushes. Birthday parties. Grad receptions. Wedding after-parties. Take the patio, the upstairs bar, the basement nightclub  or all of it. Up to 500 guests, custom menus, and Shelly handling every detail so you don't have to.</p>
        <p class="events-contact-line">
          Call Shelly Toth &nbsp;&middot;&nbsp;
          <a href={`tel:${(settings.shellyPhone || '5173334040').replace(/\D/g,'')}`}>{settings.shellyPhone || '517-333-4040'}</a>
          &nbsp;&middot;&nbsp; {settings.shellyAvailability || 'Mon–Fri, 9am–5pm'}
        </p>
      </div>

      <!-- RIGHT: booking form -->
      <div class="events-form-col reveal reveal-delay-1">
        <form id="booking-form" class="booking-form"
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST" novalidate>
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off">
          <div class="bf-header">
            <img src="/Photos/harpers-logo.png" alt="Harper's Restaurant &amp; Brewpub" class="bf-logo"
              onerror="this.style.display='none'">
            <span class="bf-header-label">Start Your Booking</span>
          </div>
          <div class="bf-error" id="bf-error" role="alert">Please check the highlighted fields and try again.</div>
          <div class="bf-row">
            <div class="bf-group">
              <label for="bf-name">Full Name <span class="bf-req" aria-hidden="true">*</span></label>
              <input type="text" id="bf-name" name="name" required placeholder="Your name" autocomplete="name">
            </div>
            <div class="bf-group">
              <label for="bf-email">Email Address <span class="bf-req" aria-hidden="true">*</span></label>
              <input type="email" id="bf-email" name="email" required placeholder="you@example.com" autocomplete="email">
            </div>
          </div>
          <div class="bf-row">
            <div class="bf-group">
              <label for="bf-phone">Phone Number <span class="bf-req" aria-hidden="true">*</span></label>
              <input type="tel" id="bf-phone" name="phone" required placeholder="(555) 555-5555" autocomplete="tel">
            </div>
            <div class="bf-group">
              <label for="bf-event-type">Event Type <span class="bf-req" aria-hidden="true">*</span></label>
              <select id="bf-event-type" name="event_type" required>
                <option value="" disabled selected>Select event type</option>
                <option value="Birthday Party">Birthday Party</option>
                <option value="Greek Life / Fraternity">Greek Life / Fraternity</option>
                <option value="Wedding After-Party">Wedding After-Party</option>
                <option value="Corporate Event">Corporate Event</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>
          <div class="bf-row">
            <div class="bf-group">
              <label for="bf-date">Event Date <span class="bf-req" aria-hidden="true">*</span></label>
              <input type="date" id="bf-date" name="event_date" required>
            </div>
            <div class="bf-group">
              <label for="bf-guests">Est. Guest Count <span class="bf-req" aria-hidden="true">*</span></label>
              <select id="bf-guests" name="guest_count" required>
                <option value="" disabled selected>Select range</option>
                <option value="Under 50">Under 50</option>
                <option value="50–100">50–100</option>
                <option value="100–200">100–200</option>
                <option value="200–500">200–500</option>
              </select>
            </div>
          </div>
          <div class="bf-group">
            <label for="bf-space">Which Space <span class="bf-req" aria-hidden="true">*</span></label>
            <select id="bf-space" name="space" required>
              <option value="" disabled selected>Select a space</option>
              <option value="Upstairs Bar">Upstairs Bar</option>
              <option value="The Patio">The Patio</option>
              <option value="Fireplace Room">Fireplace Room</option>
              <option value="Club Rush Downstairs">Club Rush Downstairs</option>
              <option value="Full Venue">Full Venue</option>
            </select>
          </div>
          <div class="bf-group">
            <label for="bf-notes">Additional Notes</label>
            <textarea id="bf-notes" name="notes" rows="2" placeholder="Tell us about your event, any special requests&hellip;"></textarea>
          </div>
          <button type="submit" class="btn btn-primary bf-submit">Send Booking Request</button>
          <p class="bf-required-note">* Required fields</p>
        </form>
        <div class="booking-success" id="booking-success" aria-live="polite">
          <div class="bs-check" aria-hidden="true">&#10003;</div>
          <h3 class="bs-title">Request Sent!</h3>
          <p class="bs-body">Thanks, Shelly will be in touch within one business day. To reach her sooner, call <a href={`tel:${(settings.shellyPhone || '5173334040').replace(/\D/g,'')}`}>{settings.shellyPhone || '517-333-4040'}</a>.</p>
        </div>
      </div>

      <!-- Quote: col 1 row 2 on desktop, after form in DOM so mobile shows form first -->
      <div class="events-quote reveal">
        <div class="pullquote-wrap">
          <blockquote class="pullquote">
            &ldquo;Harper's is the place for everyone! With a variety of food and drink choices, there's something that every person will love.&rdquo;
          </blockquote>
          <cite class="pullquote-cite">Megan Whitelaw &nbsp;&middot;&nbsp; Facebook</cite>
        </div>
      </div>
    </div>
